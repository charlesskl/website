---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/home.css';
import '../../styles/preview.css';

const milestones = [
  { year: '1987', text: 'Founded in Sha Tau Kok — the first step in a 39-year manufacturing journey.' },
  { year: '2000', text: 'First soft toy production line launched — entering plush and costume manufacturing.' },
  { year: '2010', text: 'Doll production lines integrated sewing craftsmanship with plastic molding technology.' },
  { year: '2016', text: 'Entered remote control vehicle manufacturing — our highest-complexity category.' },
  { year: '2023', text: 'Officially entered Indonesia — a key milestone in global supply chain diversification.' },
  { year: '2025', text: 'Indonesia Phase II commences — strengthening responsiveness to international markets.' },
];
---

<BaseLayout
  title="History variants (parallax) — Preview"
  description="Three parallax-driven history layouts"
  lang="en"
  canonical="https://royalregentgroup.com/preview/history"
  ogLocale="en_US"
  ogLocaleAlternates={[]}
  dataPage="preview"
>
  <Nav lang="en" />

  <div class="preview-wrap">
    <div class="preview-intro">
      <div class="preview-eyebrow">History — 3 parallax variants</div>
      <h1>Pick a parallax style for the history section.</h1>
      <p>All three are scroll-driven: the visual responds to scroll position frame-by-frame.</p>
    </div>

    <!-- VARIANT A — Scroll-scrubbed video playback -->
    <div class="preview-variant">
      <div class="preview-label">Variant A · Scroll-scrubbed video <em>(scroll controls the video's playhead; year + milestone change with frame)</em></div>
      <section class="ph-a" id="phA">
        <div class="ph-a-wrap" id="phAWrap">
          <div class="ph-a-inner" id="phAInner">
            <div class="ph-a-video-layer">
              <video class="ph-a-video" id="phAVideo" muted playsinline preload="auto">
                <source src="/assets/videos/history.mp4" type="video/mp4">
              </video>
              <div class="ph-a-video-overlay"></div>
            </div>
            <div class="ph-a-content">
              <div class="ph-a-tag">Development history</div>
              <div class="ph-a-year-big" id="phAYear">1987</div>
              <div class="ph-a-msg-area">
                {milestones.map((m, i) => (
                  <div class={`ph-a-msg${i === 0 ? ' active' : ''}`} data-index={i}>
                    <p>{m.text}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="ph-a-timeline">
              {milestones.map((m, i) => (
                <div class={`ph-a-tl-node${i === 0 ? ' active' : ''}`} data-index={i}>
                  <div class="ph-a-tl-dot"></div>
                  <span>{m.year}</span>
                </div>
              ))}
              <div class="ph-a-tl-fill" id="phATlFill"></div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- VARIANT B — Layered speed-parallax slides -->
    <div class="preview-variant">
      <div class="preview-label">Variant B · Layered speed parallax <em>(background, year text, and milestone card each scroll at different speeds)</em></div>
      <section class="ph-b">
        <div class="ph-b-header container">
          <div class="section-label">Our Story</div>
          <h2 class="section-title">39 years.<br><span>One unbroken thread.</span></h2>
        </div>
        {milestones.map((m, i) => (
          <div class={`ph-b-slide ph-b-slide-${i}`} data-index={i}>
            <div class="ph-b-bg" data-speed="-0.35"></div>
            <div class="ph-b-year" data-speed="0.5">{m.year}</div>
            <div class="ph-b-card" data-speed="0">
              <div class="ph-b-card-eyebrow">Milestone 0{i + 1} / 06</div>
              <p>{m.text}</p>
            </div>
          </div>
        ))}
      </section>
    </div>

    <!-- VARIANT C — Horizontal pinned parallax -->
    <div class="preview-variant">
      <div class="preview-label">Variant C · Horizontal pinned parallax <em>(vertical scroll → horizontal motion; layers drift at different horizontal rates)</em></div>
      <section class="ph-c" id="phC">
        <div class="ph-c-wrap" id="phCWrap">
          <div class="ph-c-inner" id="phCInner">
            <div class="ph-c-header">
              <div class="ph-c-tag">Development history</div>
              <h2>39 years.<br>Four decades of motion.</h2>
            </div>
            <div class="ph-c-stage">
              <!-- Slow drifting background year text -->
              <div class="ph-c-years-bg" id="phCYearsBg">
                {milestones.map((m) => <span>{m.year}</span>)}
              </div>
              <!-- Medium-speed video layer -->
              <div class="ph-c-video-layer" id="phCVideoLayer">
                <video class="ph-c-video" autoplay muted loop playsinline>
                  <source src="/assets/videos/history.mp4" type="video/mp4">
                </video>
                <div class="ph-c-video-tint"></div>
              </div>
              <!-- Fast milestone cards -->
              <div class="ph-c-cards" id="phCCards">
                {milestones.map((m) => (
                  <div class="ph-c-card">
                    <div class="ph-c-card-year">{m.year}</div>
                    <p>{m.text}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="ph-c-progress">
              <div class="ph-c-progress-fill" id="phCProgressFill"></div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <Footer lang="en" />

  <Fragment slot="page-scripts">
    <script is:inline>
      (function(){
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else { init(); }

        function init() {
          if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
          gsap.registerPlugin(ScrollTrigger);

          // ═══ Variant A — scroll-scrubbed video ═══
          (function(){
            var video = document.getElementById('phAVideo');
            var wrap = document.getElementById('phAWrap');
            var inner = document.getElementById('phAInner');
            var yearEl = document.getElementById('phAYear');
            var msgs = Array.prototype.slice.call(document.querySelectorAll('#phA .ph-a-msg'));
            var nodes = Array.prototype.slice.call(document.querySelectorAll('#phA .ph-a-tl-node'));
            var tlFill = document.getElementById('phATlFill');
            if (!video || !wrap || window.innerWidth < 900) return;

            var years = ['1987','2000','2010','2016','2023','2025'];
            var lastIdx = -1;

            function ensureDuration(cb) {
              if (isFinite(video.duration) && video.duration > 0) { cb(); return; }
              video.addEventListener('loadedmetadata', cb, { once: true });
            }

            ensureDuration(function(){
              var dur = video.duration || 8;
              ScrollTrigger.create({
                trigger: wrap,
                start: 'top top',
                end: '+=' + (years.length * window.innerHeight * 0.9),
                pin: inner,
                scrub: 0.4,
                invalidateOnRefresh: true,
                onUpdate: function(self){
                  var p = self.progress;
                  // Scrub video
                  video.currentTime = Math.min(dur - 0.05, p * dur);
                  // Active index
                  var idx = Math.min(years.length - 1, Math.floor(p * years.length));
                  if (idx !== lastIdx) {
                    lastIdx = idx;
                    if (yearEl) yearEl.textContent = years[idx];
                    msgs.forEach(function(m, j){ m.classList.toggle('active', j === idx); });
                    nodes.forEach(function(n, j){ n.classList.toggle('active', j === idx); });
                  }
                  if (tlFill) tlFill.style.transform = 'scaleX(' + p + ')';
                }
              });
            });
          })();

          // ═══ Variant B — layered speed parallax ═══
          (function(){
            var slides = document.querySelectorAll('.ph-b-slide');
            if (!slides.length) return;
            slides.forEach(function(slide){
              var layers = slide.querySelectorAll('[data-speed]');
              layers.forEach(function(layer){
                var speed = parseFloat(layer.getAttribute('data-speed')) || 0;
                if (speed === 0) return;
                gsap.fromTo(layer,
                  { yPercent: -speed * 40 },
                  {
                    yPercent: speed * 40,
                    ease: 'none',
                    scrollTrigger: {
                      trigger: slide,
                      start: 'top bottom',
                      end: 'bottom top',
                      scrub: true,
                    }
                  }
                );
              });
            });
          })();

          // ═══ Variant C — horizontal pinned parallax ═══
          (function(){
            var wrap = document.getElementById('phCWrap');
            var inner = document.getElementById('phCInner');
            var yearsBg = document.getElementById('phCYearsBg');
            var videoLayer = document.getElementById('phCVideoLayer');
            var cards = document.getElementById('phCCards');
            var fill = document.getElementById('phCProgressFill');
            if (!wrap || !inner || !yearsBg || !cards || window.innerWidth < 900) return;

            var cardsWidth = cards.scrollWidth;
            var viewportWidth = window.innerWidth;
            var horizDistance = cardsWidth - viewportWidth + 200;

            ScrollTrigger.create({
              trigger: wrap,
              start: 'top top',
              end: '+=' + (horizDistance * 1.3),
              pin: inner,
              scrub: 0.5,
              invalidateOnRefresh: true,
              onUpdate: function(self){
                var p = self.progress;
                cards.style.transform = 'translate3d(-' + (p * horizDistance) + 'px,0,0)';
                yearsBg.style.transform = 'translate3d(-' + (p * horizDistance * 0.35) + 'px,0,0)';
                if (videoLayer) videoLayer.style.transform = 'translate3d(-' + (p * horizDistance * 0.6) + 'px,0,0) scale(1.05)';
                if (fill) fill.style.transform = 'scaleX(' + p + ')';
              }
            });
          })();
        }
      })();
    </script>
  </Fragment>
</BaseLayout>
