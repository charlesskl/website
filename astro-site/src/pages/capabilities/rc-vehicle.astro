---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/capability.css';

const lang = 'en' as const;
const prefix = '';
---

<BaseLayout
  title="RC Vehicle Manufacturer — Royal Regent Toys"
  description="Royal Regent Toys RC vehicle manufacturing — SMT electronics, chassis engineering & performance testing. OEM remote control toy manufacturer for global brands."
  lang="en"
  canonical="https://royalregentgroup.com/capabilities/rc-vehicle.html"
  ogLocale="en_US"
  ogLocaleAlternates={['zh_TW', 'id_ID']}
  dataPage="capabilities-rc-vehicle"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, RC vehicle manufacturer, remote control toy factory, SMT electronics toys, OEM RC toys, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://royalregentgroup.com/" },
            { "@type": "ListItem", "position": 2, "name": "Capabilities", "item": "https://royalregentgroup.com/#capabilities" },
            { "@type": "ListItem", "position": 3, "name": "RC Vehicles", "item": "https://royalregentgroup.com/capabilities/rc-vehicle.html" }
          ]
        },
        {
          "@type": "Service",
          "name": "RC Vehicle Manufacturing",
          "provider": {"@type": "Organization", "name": "Royal Regent Toys", "url": "https://royalregentgroup.com"},
          "description": "OEM remote control toy manufacturing — SMT electronics, chassis engineering & performance testing for global brands.",
          "url": "https://royalregentgroup.com/capabilities/rc-vehicle.html",
          "serviceType": "Toy Manufacturing",
          "areaServed": "Worldwide"
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <section class="sub-hero" id="subHero">
    <div class="hero-grid-pattern"></div>
    <div class="aurora"><div class="aurora-blob"></div><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="sub-hero-content">
      <div class="breadcrumb" id="heroBreadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>RC Vehicles</span>
      </div>
      <span class="sub-hero-tag" id="heroTag">RC Vehicles</span>
      <h1 class="sub-hero-title" id="heroTitle">Remote control<br><span class="text-gradient">vehicles</span></h1>
      <p class="sub-hero-sub" id="heroSub">Comprehensive OEM manufacturing for RC toy cars, from basic to advanced models — structural strength, control precision, and full electronic safety compliance.</p>
    </div>
    <div class="sub-hero-scroll" id="heroScroll"><span>Scroll</span><div class="scroll-line"></div></div>
  </section>

  <div class="main-content" id="main-content">

    <section class="editorial">
      <div class="container">
        <div class="editorial-watermark">RC</div>
        <div class="editorial-inner">
          <div class="editorial-left">
            <span class="section-label reveal-up">Manufacturing overview</span>
            <div class="editorial-intro reveal-up">
              <div class="editorial-intro-line"></div>
              <div>
                <p>
                  <span class="stmt-line">Our most complex category.</span>
                  <span class="stmt-line">Mechanical meets electronic.</span>
                  <span class="stmt-line">Concept to certified product.</span>
                </p>
                <div class="stmt-rule"></div>
              </div>
            </div>
          </div>
          <div class="editorial-right">
            <div class="editorial-features">
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">01</div>
                <div><h3>In-house SMT electronics</h3><p>Our dedicated Surface Mount Technology department handles circuit board assembly and electronic integration internally — giving us full control over motor performance, control responsiveness, and consistency across every unit we ship.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">02</div>
                <div><h3>Structural engineering for play durability</h3><p>Years of RC vehicle production have refined how we design and reinforce chassis and body structures. Built to withstand real-world play, our vehicles are stress-tested for the handling and impact children's RC toys demand.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">03</div>
                <div><h3>Full range capability</h3><p>From simple forward/reverse models to advanced multi-function vehicles with lights, sound, and complex control systems — our combined SMT, plastic molding, and automation capabilities let us handle the full RC spectrum under one roof.</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="photo-panels">
        <div class="photo-panel">
          <img src="/assets/electronics-assembly.webp" alt="RC vehicles manufacturing" loading="lazy" width="1600" height="1066">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Electronics Assembly</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/rc-assembly.webp" alt="RC electronics assembly" loading="lazy" width="1600" height="1066">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>RC Assembly</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/rc-vehicle-testing.webp" alt="RC vehicle testing" loading="lazy" width="784" height="1168">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Vehicle Testing</span></div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container reveal-up">
        <h2>Ready to discuss your project?</h2>
        <p>Tell us about your requirements and our team will get back to you promptly.</p>
        <a href="/contact.html" class="btn btn-primary magnetic" data-strength="0.2">Contact Us →</a>
      </div>
    </section>

    <!-- SEE ALSO -->
    <section class="see-also">
      <div class="container">
        <span class="see-also-label">Explore other capabilities</span>
        <div class="see-also-grid">
          <a href="/capabilities/plastic-toys.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            <span>Plastic Toys</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/plush.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            <span>Plush</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/dolls.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Dolls</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/costume.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M12 3l1.5 3.2 3.5.5-2.5 2.5.6 3.5L12 11l-3.1 1.7.6-3.5L7 6.7l3.5-.5z"/><path d="M5 16l-1.5 3.2-3.5.5L2.5 22l-.6 2L5 22.3 8.1 24l-.6-2L10 19.5l-3.5-.5z"/><path d="M19 16l-1.5 3.2-3.5.5 2.5 2.5-.6 2L19 22.3l3.1 1.7-.6-2L24 19.5l-3.5-.5z"/></svg>
            <span>Costumes</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/capability-animations.js"></script>
  </Fragment>
</BaseLayout>
