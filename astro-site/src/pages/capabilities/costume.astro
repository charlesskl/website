---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/capability.css';

const lang = 'en' as const;
const prefix = '';
---

<BaseLayout
  title="Costume Manufacturer — Royal Regent Toys"
  description="Royal Regent Toys costume manufacturing — pattern cutting, sewing, plastic components & character-ready apparel. OEM character costume manufacturer."
  lang="en"
  canonical="https://royalregentgroup.com/capabilities/costume.html"
  ogLocale="en_US"
  ogLocaleAlternates={['zh_TW', 'id_ID']}
  dataPage="capabilities-costume"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, costume manufacturer, character costume OEM, costume factory, licensed character costumes, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://royalregentgroup.com/" },
            { "@type": "ListItem", "position": 2, "name": "Capabilities", "item": "https://royalregentgroup.com/#capabilities" },
            { "@type": "ListItem", "position": 3, "name": "Costumes", "item": "https://royalregentgroup.com/capabilities/costume.html" }
          ]
        },
        {
          "@type": "Service",
          "name": "Costume Manufacturing",
          "provider": {"@type": "Organization", "name": "Royal Regent Toys", "url": "https://royalregentgroup.com"},
          "description": "OEM character costume manufacturing — pattern cutting, sewing, plastic components & character-ready apparel.",
          "url": "https://royalregentgroup.com/capabilities/costume.html",
          "serviceType": "Toy Manufacturing",
          "areaServed": "Worldwide"
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <section class="sub-hero" id="subHero">
    <div class="hero-grid-pattern"></div>
    <div class="aurora"><div class="aurora-blob"></div><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="sub-hero-content">
      <div class="breadcrumb" id="heroBreadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>Costumes</span>
      </div>
      <span class="sub-hero-tag" id="heroTag">Costumes</span>
      <h1 class="sub-hero-title" id="heroTitle">Character &amp;<br><span class="text-gradient">costumes</span></h1>
      <p class="sub-hero-sub" id="heroSub">Soft, safe fabrics with detailed finishing for licensed and custom character costume designs — from dress-up to themed collections for children.</p>
    </div>
    <div class="sub-hero-scroll" id="heroScroll"><span>Scroll</span><div class="scroll-line"></div></div>
  </section>

  <div class="main-content" id="main-content">

    <section class="editorial">
      <div class="container">
        <div class="editorial-watermark">Costumes</div>
        <div class="editorial-inner">
          <div class="editorial-left">
            <span class="section-label reveal-up">Manufacturing overview</span>
            <div class="editorial-intro reveal-up">
              <div class="editorial-intro-line"></div>
              <div>
                <p>
                  <span class="stmt-line">Cut, sewn, and finished.</span>
                  <span class="stmt-line">All under one roof.</span>
                  <span class="stmt-line">Licensed character ready.</span>
                </p>
                <div class="stmt-rule"></div>
              </div>
            </div>
          </div>
          <div class="editorial-right">
            <div class="editorial-features">
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">01</div>
                <div><h3>Simple to complex costume construction</h3><p>Our sewing and fabrication lines handle the full spectrum — from straightforward princess dresses to highly structured character costumes with multiple components, foam padding, moulded plastic accessories, and detailed embellishment. The complexity doesn't change the factory.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">02</div>
                <div><h3>Plastic &amp; soft goods in one order</h3><p>Character costumes often require plastic masks, weapons, armour pieces, and props alongside the garment itself. With our plastic molding and sewing departments under one roof, we produce the complete costume package without splitting your order.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">03</div>
                <div><h3>Built for the toy trade</h3><p>We work with toy companies and brand owners who hold licenses — understanding the production standards, quality expectations, and delivery requirements that come with bringing character costumes to retail markets worldwide.</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="photo-panels">
        <div class="photo-panel">
          <img src="/assets/fabric-cutting.webp" alt="Costume manufacturing" loading="lazy" width="1920" height="1280">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Fabric Cutting</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/costume01.webp" alt="Costume sewing production" loading="lazy" width="1279" height="1706">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Sewing Production</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/costume.webp" alt="Costume quality finishing" loading="lazy" width="1920" height="1440">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Quality Finishing</span></div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container reveal-up">
        <h2>Ready to discuss your project?</h2>
        <p>Tell us about your requirements and our team will get back to you promptly.</p>
        <a href="/contact.html" class="btn btn-primary magnetic" data-strength="0.2">Contact Us →</a>
      </div>
    </section>

    <!-- SEE ALSO -->
    <section class="see-also">
      <div class="container">
        <span class="see-also-label">Explore other capabilities</span>
        <div class="see-also-grid">
          <a href="/capabilities/plastic-toys.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            <span>Plastic Toys</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/plush.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            <span>Plush</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/dolls.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Dolls</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/rc-vehicle.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <span>RC Vehicles</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/capability-animations.js"></script>
  </Fragment>
</BaseLayout>
