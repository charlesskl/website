---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/capability.css';

const lang = 'en' as const;
const prefix = '';
---

<BaseLayout
  title="Doll Manufacturer OEM — Royal Regent Toys"
  description="Royal Regent Toys doll manufacturing — face painting, hair rooting, outfit assembly & quality finishing. OEM doll manufacturer for fashion dolls & baby dolls."
  lang="en"
  canonical="https://royalregentgroup.com/capabilities/dolls.html"
  ogLocale="en_US"
  ogLocaleAlternates={['zh_TW', 'id_ID']}
  dataPage="capabilities-dolls"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, doll manufacturer OEM, fashion doll factory, baby doll manufacturer, hair rooting, face painting dolls, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://royalregentgroup.com/" },
            { "@type": "ListItem", "position": 2, "name": "Capabilities", "item": "https://royalregentgroup.com/#capabilities" },
            { "@type": "ListItem", "position": 3, "name": "Dolls", "item": "https://royalregentgroup.com/capabilities/dolls.html" }
          ]
        },
        {
          "@type": "Service",
          "name": "Doll Manufacturing",
          "provider": {"@type": "Organization", "name": "Royal Regent Toys", "url": "https://royalregentgroup.com"},
          "description": "OEM doll manufacturing — face painting, hair rooting, outfit assembly & quality finishing for fashion dolls & baby dolls.",
          "url": "https://royalregentgroup.com/capabilities/dolls.html",
          "serviceType": "Toy Manufacturing",
          "areaServed": "Worldwide"
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <!-- HERO -->
  <section class="sub-hero" id="subHero">
    <div class="hero-grid-pattern"></div>
    <div class="aurora"><div class="aurora-blob"></div><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="sub-hero-content">
      <div class="breadcrumb" id="heroBreadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>Dolls</span>
      </div>
      <span class="sub-hero-tag" id="heroTag">Dolls</span>
      <h1 class="sub-hero-title" id="heroTitle">Fashion &amp; baby<br><span class="text-gradient">dolls</span></h1>
      <p class="sub-hero-sub" id="heroSub">Complete OEM doll manufacturing — face painting, hair rooting, and outfit assembly — produced to EN 71 and ASTM F963 safety standards for US and EU markets.</p>
    </div>
    <div class="sub-hero-scroll" id="heroScroll"><span>Scroll</span><div class="scroll-line"></div></div>
  </section>

  <div class="main-content" id="main-content">

    <section class="editorial">
      <div class="container">
        <div class="editorial-watermark">Dolls</div>
        <div class="editorial-inner">
          <div class="editorial-left">
            <span class="section-label reveal-up">Manufacturing overview</span>
            <div class="editorial-intro reveal-up">
              <div class="editorial-intro-line"></div>
              <div>
                <p>
                  <span class="stmt-line">Detail at every scale.</span>
                  <span class="stmt-line">Face paint to final stitch.</span>
                  <span class="stmt-line">Full-process production.</span>
                </p>
                <div class="stmt-rule"></div>
              </div>
            </div>
          </div>
          <div class="editorial-right">
            <div class="editorial-features">
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">01</div>
                <div><h3>Face decoration &amp; finishing</h3><p>With a dedicated face decoration floor equipped for Digital Inkjet (DIJ), precision painting, and pad printing — we have the capability to execute any face finish your design requires, consistently across high-volume runs. Both baby doll and fashion doll lines produced entirely in-house.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">02</div>
                <div><h3>Hair rooting</h3><p>Nylon and synthetic hair rooting with custom colours and styles — engineered for durability and play-safe performance throughout the product's life.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">03</div>
                <div><h3>Outfit &amp; accessory assembly</h3><p>Full garment production and accessory assembly in-house — supporting licensed IP requirements, custom designs, and complete dress-up doll packages.</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="photo-panels">
        <div class="photo-panel">
          <img src="/assets/face-painting.webp" alt="Dolls manufacturing" loading="lazy" width="1600" height="1066">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Face Painting</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/doll.webp" alt="Doll assembly" loading="lazy" width="1024" height="576">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Assembly</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/hair-rooting.webp" alt="Doll hair rooting" loading="lazy" width="1152" height="896">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Hair Rooting</span></div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container reveal-up">
        <h2>Ready to discuss your project?</h2>
        <p>Tell us about your requirements and our team will get back to you promptly.</p>
        <a href="/contact.html" class="btn btn-primary magnetic" data-strength="0.2">Contact Us →</a>
      </div>
    </section>

    <!-- SEE ALSO -->
    <section class="see-also">
      <div class="container">
        <span class="see-also-label">Explore other capabilities</span>
        <div class="see-also-grid">
          <a href="/capabilities/plastic-toys.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            <span>Plastic Toys</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/plush.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            <span>Plush</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/rc-vehicle.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <span>RC Vehicles</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/capabilities/costume.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M12 3l1.5 3.2 3.5.5-2.5 2.5.6 3.5L12 11l-3.1 1.7.6-3.5L7 6.7l3.5-.5z"/><path d="M5 16l-1.5 3.2-3.5.5L2.5 22l-.6 2L5 22.3 8.1 24l-.6-2L10 19.5l-3.5-.5z"/><path d="M19 16l-1.5 3.2-3.5.5 2.5 2.5-.6 2L19 22.3l3.1 1.7-.6-2L24 19.5l-3.5-.5z"/></svg>
            <span>Costumes</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/capability-animations.js"></script>
  </Fragment>
</BaseLayout>
