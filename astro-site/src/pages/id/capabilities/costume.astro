---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import '../../../styles/capability.css';

const lang = 'id' as const;
const prefix = '/id';
---

<BaseLayout
  title="Produsen Kostum — Royal Regent Toys | PT RRI, PT RRM"
  description="Manufaktur kostum Royal Regent Toys — pemotongan pola, penjahitan, komponen plastik & pakaian siap karakter. Produsen kostum karakter OEM. PT RRI, PT RRM."
  lang="id"
  canonical="https://royalregentgroup.com/id/capabilities/costume.html"
  ogLocale="id_ID"
  ogLocaleAlternates={['en_US', 'zh_TW']}
  dataPage="capabilities-costume"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, produsen kostum, kostum karakter OEM, pabrik kostum, kostum karakter berlisensi, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://royalregentgroup.com/id/" },
            { "@type": "ListItem", "position": 2, "name": "Kemampuan", "item": "https://royalregentgroup.com/id/#capabilities" },
            { "@type": "ListItem", "position": 3, "name": "Kostum", "item": "https://royalregentgroup.com/id/capabilities/costume.html" }
          ]
        },
        {
          "@type": "Service",
          "name": "Manufaktur Kostum",
          "provider": {"@type": "Organization", "name": "Royal Regent Toys", "url": "https://royalregentgroup.com"},
          "description": "Manufaktur kostum karakter OEM — pemotongan pola, penjahitan, komponen plastik & pakaian siap karakter.",
          "url": "https://royalregentgroup.com/id/capabilities/costume.html",
          "serviceType": "Toy Manufacturing",
          "areaServed": "Worldwide"
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <section class="sub-hero" id="subHero">
    <div class="hero-grid-pattern"></div>
    <div class="aurora"><div class="aurora-blob"></div><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="sub-hero-content">
      <div class="breadcrumb" id="heroBreadcrumb">
        <a href="/id/">Beranda</a><span class="sep">/</span><span>Kostum</span>
      </div>
      <span class="sub-hero-tag" id="heroTag">Kostum</span>
      <h1 class="sub-hero-title" id="heroTitle">Karakter &amp;<br><span class="text-gradient">kostum</span></h1>
      <p class="sub-hero-sub" id="heroSub">Kain yang lembut dan aman dengan finishing detail untuk desain kostum karakter berlisensi dan khusus — dari dress-up hingga koleksi bertema untuk anak-anak.</p>
    </div>
    <div class="sub-hero-scroll" id="heroScroll"><span>Gulir</span><div class="scroll-line"></div></div>
  </section>

  <div class="main-content" id="main-content">

    <section class="editorial">
      <div class="container">
        <div class="editorial-watermark">Costumes</div>
        <div class="editorial-inner">
          <div class="editorial-left">
            <span class="section-label reveal-up">Ikhtisar manufaktur</span>
            <div class="editorial-intro reveal-up">
              <div class="editorial-intro-line"></div>
              <div>
                <p>
                  <span class="stmt-line">Dipotong, dijahit, dan diselesaikan.</span>
                  <span class="stmt-line">Semua di bawah satu atap.</span>
                  <span class="stmt-line">Siap karakter berlisensi.</span>
                </p>
                <div class="stmt-rule"></div>
              </div>
            </div>
          </div>
          <div class="editorial-right">
            <div class="editorial-features">
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">01</div>
                <div><h3>Konstruksi kostum sederhana hingga kompleks</h3><p>Lini penjahitan dan fabrikasi kami menangani spektrum penuh — dari gaun putri yang sederhana hingga kostum karakter yang sangat terstruktur dengan banyak komponen, padding busa, aksesori plastik yang dicetak, dan embellishment detail. Kompleksitas tidak mengubah pabrik.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">02</div>
                <div><h3>Plastik &amp; barang lembut dalam satu pesanan</h3><p>Kostum karakter sering memerlukan topeng plastik, senjata, potongan baju besi, dan props bersama pakaian itu sendiri. Dengan departemen cetak plastik dan penjahitan kami di bawah satu atap, kami memproduksi paket kostum lengkap tanpa membagi pesanan Anda.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">03</div>
                <div><h3>Dibangun untuk perdagangan mainan</h3><p>Kami bekerja dengan perusahaan mainan dan pemilik merek yang memegang lisensi — memahami standar produksi, harapan kualitas, dan persyaratan pengiriman yang datang dengan membawa kostum karakter ke pasar ritel di seluruh dunia.</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="photo-panels">
        <div class="photo-panel">
          <img src="/assets/fabric-cutting.webp" alt="Manufaktur kostum" loading="lazy" width="1920" height="1280">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Pemotongan Kain</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/costume01.webp" alt="Produksi penjahitan kostum" loading="lazy" width="1279" height="1706">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Produksi Penjahitan</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/costume.webp" alt="Finishing kualitas kostum" loading="lazy" width="1920" height="1440">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Finishing Kualitas</span></div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container reveal-up">
        <h2>Siap mendiskusikan proyek Anda?</h2>
        <p>Sampaikan kebutuhan Anda dan tim kami akan segera menghubungi Anda.</p>
        <a href="/id/contact.html" class="btn btn-primary magnetic" data-strength="0.2">Hubungi Kami →</a>
      </div>
    </section>

    <!-- SEE ALSO -->
    <section class="see-also">
      <div class="container">
        <span class="see-also-label">Jelajahi kapabilitas lainnya</span>
        <div class="see-also-grid">
          <a href="/id/capabilities/plastic-toys.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            <span>Mainan Plastik</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/id/capabilities/plush.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            <span>Boneka Plush</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/id/capabilities/dolls.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Boneka</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/id/capabilities/rc-vehicle.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <span>Kendaraan RC</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/capability-animations.js"></script>
  </Fragment>
</BaseLayout>
