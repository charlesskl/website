---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import '../../../styles/capability.css';

const lang = 'id' as const;
const prefix = '/id';
---

<BaseLayout
  title="Produsen Boneka Plush — Royal Regent Toys | PT RRI, PT RRM"
  description="Manufaktur boneka plush Royal Regent Toys — pemotongan, penjahitan, pengisian & integrasi elektronik. Produsen boneka plush OEM untuk merek global. PT RRI, PT RRM."
  lang="id"
  canonical="https://royalregentgroup.com/id/capabilities/plush.html"
  ogLocale="id_ID"
  ogLocaleAlternates={['en_US', 'zh_TW']}
  dataPage="capabilities-plush"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, produsen boneka plush, pabrik mainan lembut, boneka plush OEM, boneka elektronik, boneka IP berlisensi, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://royalregentgroup.com/id/" },
            { "@type": "ListItem", "position": 2, "name": "Kemampuan", "item": "https://royalregentgroup.com/id/#capabilities" },
            { "@type": "ListItem", "position": 3, "name": "Boneka Plush", "item": "https://royalregentgroup.com/id/capabilities/plush.html" }
          ]
        },
        {
          "@type": "Service",
          "name": "Manufaktur Boneka Plush",
          "provider": {"@type": "Organization", "name": "Royal Regent Toys", "url": "https://royalregentgroup.com"},
          "description": "Manufaktur boneka plush OEM — pemotongan, penjahitan, pengisian & integrasi elektronik.",
          "url": "https://royalregentgroup.com/id/capabilities/plush.html",
          "serviceType": "Toy Manufacturing",
          "areaServed": "Worldwide"
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <!-- HERO -->
  <section class="sub-hero" id="subHero">
    <div class="hero-grid-pattern"></div>
    <div class="aurora">
      <div class="aurora-blob"></div>
      <div class="aurora-blob"></div>
      <div class="aurora-blob"></div>
    </div>
    <div class="sub-hero-content">
      <div class="breadcrumb" id="heroBreadcrumb">
        <a href={`${prefix}/`}>Beranda</a><span class="sep">/</span>
        <span>Boneka Plush</span>
      </div>
      <span class="sub-hero-tag" id="heroTag">Boneka Plush</span>
      <h1 class="sub-hero-title" id="heroTitle">Figur plush &amp;<br><span class="text-gradient">mainan lembut</span></h1>
      <p class="sub-hero-sub" id="heroSub">Plush berlisensi IP, hadiah, dan merchandise bermerek diproduksi dengan lini produksi mainan lembut internal lengkap — pemotongan, penjahitan, pengisian, dan inspeksi akhir di satu atap.</p>
    </div>
    <div class="sub-hero-scroll" id="heroScroll"><span>Gulir</span><div class="scroll-line"></div></div>
  </section>

  <div class="main-content" id="main-content">

  <!-- EDITORIAL -->
  <section class="editorial">
    <div class="container">
      <div class="editorial-watermark">Plush</div>
      <div class="editorial-inner">

        <div class="editorial-left">
          <span class="section-label reveal-up">Ikhtisar manufaktur</span>

          <div class="editorial-intro reveal-up">
            <div class="editorial-intro-line"></div>
            <div>
              <p>
                <span class="stmt-line">Dari pola ke produk.</span>
                <span class="stmt-line">Setiap jahitan dikerjakan internal.</span>
                <span class="stmt-line">Berlisensi dan siap untuk merek.</span>
              </p>
              <div class="stmt-rule"></div>
            </div>
          </div>
        </div>

        <div class="editorial-right">
          <div class="editorial-features">
            <div class="editorial-feat reveal-up">
              <div class="editorial-feat-num">01</div>
              <div>
                <h3>Plush elektronik &amp; hibrida, dibuat sederhana</h3>
                <p>Dengan departemen elektronik SMT internal dan kemampuan manufaktur plastik, kami dapat memproduksi plush interaktif, plush elektronik, dan mainan lembut apa pun yang memerlukan komponen plastik terintegrasi — semua di satu atap. Tanpa koordinasi antar pemasok, tanpa kompromi.</p>
              </div>
            </div>
            <div class="editorial-feat reveal-up">
              <div class="editorial-feat-num">02</div>
              <div>
                <h3>Produksi plush lengkap secara internal</h3>
                <p>Dari pemilihan kain dan pemotongan pola hingga penjahitan, pengisian, bordir, dan inspeksi akhir — setiap langkah ditangani secara internal tanpa outsourcing. Disiplin kualitas yang sama yang kami terapkan di semua kategori berlaku di sini.</p>
              </div>
            </div>
            <div class="editorial-feat reveal-up">
              <div class="editorial-feat-num">03</div>
              <div>
                <h3>Pengalaman IP berlisensi &amp; pasar hadiah</h3>
                <p>Kami memproduksi plush karakter untuk pemegang IP berlisensi, merek hadiah, dan klien promosi — dengan akurasi warna, pengalaman proses persetujuan, dan konsistensi volume yang dituntut oleh kemitraan tersebut.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <div class="photo-panels">
      <div class="photo-panel">
        <img src="/assets/images/factory-pattern-cutting.webp" alt="Manufaktur boneka plush" loading="lazy" width="1600" height="1066">
        <div class="photo-panel-overlay"></div>
        <div class="photo-panel-label"><div class="label-line"></div><span>Pemotongan Pola</span></div>
      </div>
      <div class="photo-panel">
        <img src="/assets/sewing-production.webp" alt="Produksi penjahitan plush" loading="lazy" width="1314" height="774">
        <div class="photo-panel-overlay"></div>
        <div class="photo-panel-label"><div class="label-line"></div><span>Produksi Jahit</span></div>
      </div>
      <div class="photo-panel">
        <img src="/assets/quality-inspection.webp" alt="Inspeksi kualitas plush" loading="lazy" width="2450" height="1580">
        <div class="photo-panel-overlay"></div>
        <div class="photo-panel-label"><div class="label-line"></div><span>Inspeksi Kualitas</span></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container reveal-up">
      <h2>Siap mendiskusikan proyek Anda?</h2>
      <p>Sampaikan kebutuhan Anda dan tim kami akan segera menghubungi Anda.</p>
      <a href={`${prefix}/contact.html`} class="btn btn-primary magnetic" data-strength="0.2">Hubungi Kami &rarr;</a>
    </div>
  </section>

  <!-- SEE ALSO -->
  <section class="see-also">
    <div class="container">
      <span class="see-also-label">Jelajahi kapabilitas lainnya</span>
      <div class="see-also-grid">
        <a href={`${prefix}/capabilities/plastic-toys.html`} class="see-also-card">
          <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          <span>Mainan Plastik</span>
          <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`${prefix}/capabilities/dolls.html`} class="see-also-card">
          <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span>Boneka</span>
          <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`${prefix}/capabilities/rc-vehicle.html`} class="see-also-card">
          <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          <span>Kendaraan RC</span>
          <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`${prefix}/capabilities/costume.html`} class="see-also-card">
          <svg viewBox="0 0 24 24"><path d="M12 3l1.5 3.2 3.5.5-2.5 2.5.6 3.5L12 11l-3.1 1.7.6-3.5L7 6.7l3.5-.5z"/><path d="M5 16l-1.5 3.2-3.5.5L2.5 22l-.6 2L5 22.3 8.1 24l-.6-2L10 19.5l-3.5-.5z"/><path d="M19 16l-1.5 3.2-3.5.5 2.5 2.5-.6 2L19 22.3l3.1 1.7-.6-2L24 19.5l-3.5-.5z"/></svg>
          <span>Kostum</span>
          <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  </div>

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/capability-animations.js"></script>
  </Fragment>
</BaseLayout>
