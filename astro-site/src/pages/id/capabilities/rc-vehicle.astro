---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import '../../../styles/capability.css';

const lang = 'id' as const;
const prefix = '/id';
---

<BaseLayout
  title="Produsen Kendaraan RC — Royal Regent Toys | PT RRI, PT RRM"
  description="Manufaktur kendaraan RC Royal Regent Toys — elektronik SMT, engineering chassis & pengujian performa. Produsen mainan RC OEM untuk merek global."
  lang="id"
  canonical="https://royalregentgroup.com/id/capabilities/rc-vehicle.html"
  ogLocale="id_ID"
  ogLocaleAlternates={['en_US', 'zh_TW']}
  dataPage="capabilities-rc-vehicle"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, produsen kendaraan RC, pabrik mainan remote control, elektronik SMT mainan, OEM mainan RC, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://royalregentgroup.com/id/" },
            { "@type": "ListItem", "position": 2, "name": "Kemampuan", "item": "https://royalregentgroup.com/id/#capabilities" },
            { "@type": "ListItem", "position": 3, "name": "Kendaraan RC", "item": "https://royalregentgroup.com/id/capabilities/rc-vehicle.html" }
          ]
        },
        {
          "@type": "Service",
          "name": "Manufaktur Kendaraan RC",
          "provider": {"@type": "Organization", "name": "Royal Regent Toys", "url": "https://royalregentgroup.com"},
          "description": "Manufaktur mainan RC OEM — elektronik SMT, engineering chassis & pengujian performa untuk merek global.",
          "url": "https://royalregentgroup.com/id/capabilities/rc-vehicle.html",
          "serviceType": "Toy Manufacturing",
          "areaServed": "Worldwide"
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <section class="sub-hero" id="subHero">
    <div class="hero-grid-pattern"></div>
    <div class="aurora"><div class="aurora-blob"></div><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="sub-hero-content">
      <div class="breadcrumb" id="heroBreadcrumb">
        <a href="/id/">Beranda</a><span class="sep">/</span><span>Kendaraan RC</span>
      </div>
      <span class="sub-hero-tag" id="heroTag">Kendaraan RC</span>
      <h1 class="sub-hero-title" id="heroTitle">Kendaraan<br><span class="text-gradient">remote control</span></h1>
      <p class="sub-hero-sub" id="heroSub">Manufaktur OEM komprehensif untuk mobil mainan RC, dari model dasar hingga lanjutan — kekuatan struktural, presisi kontrol, dan kepatuhan keselamatan elektronik lengkap.</p>
    </div>
    <div class="sub-hero-scroll" id="heroScroll"><span>Gulir</span><div class="scroll-line"></div></div>
  </section>

  <div class="main-content" id="main-content">

    <section class="editorial">
      <div class="container">
        <div class="editorial-watermark">RC</div>
        <div class="editorial-inner">
          <div class="editorial-left">
            <span class="section-label reveal-up">Ikhtisar manufaktur</span>
            <div class="editorial-intro reveal-up">
              <div class="editorial-intro-line"></div>
              <div>
                <p>
                  <span class="stmt-line">Kategori paling kompleks kami.</span>
                  <span class="stmt-line">Mekanis bertemu elektronik.</span>
                  <span class="stmt-line">Dari konsep ke produk bersertifikat.</span>
                </p>
                <div class="stmt-rule"></div>
              </div>
            </div>
          </div>
          <div class="editorial-right">
            <div class="editorial-features">
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">01</div>
                <div><h3>Elektronik SMT dalam rumah</h3><p>Departemen Surface Mount Technology (SMT) khusus kami menangani perakitan papan sirkuit dan integrasi elektronik secara internal — memberikan kami kontrol penuh atas performa motor, responsivitas kontrol, dan konsistensi di setiap unit yang kami kirim.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">02</div>
                <div><h3>Engineering struktural untuk daya tahan bermain</h3><p>Bertahun-tahun produksi kendaraan RC telah menyempurnakan cara kami merancang dan memperkuat struktur chassis dan body. Dirancang untuk bertahan dalam permainan nyata, kendaraan kami diuji tekanan untuk menangani perlakuan dan dampak yang dituntut mainan RC anak-anak.</p></div>
              </div>
              <div class="editorial-feat reveal-up">
                <div class="editorial-feat-num">03</div>
                <div><h3>Kemampuan jangkauan penuh</h3><p>Dari model maju/mundur sederhana hingga kendaraan multi-fungsi lanjutan dengan lampu, suara, dan sistem kontrol kompleks — kemampuan SMT, pencetakan plastik, dan otomasi kombinasi kami memungkinkan kami menangani spektrum RC penuh di bawah satu atap.</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="photo-panels">
        <div class="photo-panel">
          <img src="/assets/electronics-assembly.webp" alt="Manufaktur kendaraan RC" loading="lazy" width="1600" height="1066">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Perakitan Elektronik</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/rc-assembly.webp" alt="Perakitan elektronik RC" loading="lazy" width="1600" height="1066">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Perakitan RC</span></div>
        </div>
        <div class="photo-panel">
          <img src="/assets/rc-vehicle-testing.webp" alt="Pengujian kendaraan RC" loading="lazy" width="784" height="1168">
          <div class="photo-panel-overlay"></div>
          <div class="photo-panel-label"><div class="label-line"></div><span>Pengujian Kendaraan</span></div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container reveal-up">
        <h2>Siap mendiskusikan proyek Anda?</h2>
        <p>Sampaikan kebutuhan Anda dan tim kami akan segera menghubungi Anda.</p>
        <a href="/id/contact.html" class="btn btn-primary magnetic" data-strength="0.2">Hubungi Kami →</a>
      </div>
    </section>

    <!-- SEE ALSO -->
    <section class="see-also">
      <div class="container">
        <span class="see-also-label">Jelajahi kapabilitas lainnya</span>
        <div class="see-also-grid">
          <a href="/id/capabilities/plastic-toys.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            <span>Mainan Plastik</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/id/capabilities/plush.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            <span>Boneka Plush</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/id/capabilities/dolls.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Boneka</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/id/capabilities/costume.html" class="see-also-card">
            <svg viewBox="0 0 24 24"><path d="M12 3l1.5 3.2 3.5.5-2.5 2.5.6 3.5L12 11l-3.1 1.7.6-3.5L7 6.7l3.5-.5z"/><path d="M5 16l-1.5 3.2-3.5.5L2.5 22l-.6 2L5 22.3 8.1 24l-.6-2L10 19.5l-3.5-.5z"/><path d="M19 16l-1.5 3.2-3.5.5 2.5 2.5-.6 2L19 22.3l3.1 1.7-.6-2L24 19.5l-3.5-.5z"/></svg>
            <span>Kostum</span>
            <svg class="see-also-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/capability-animations.js"></script>
  </Fragment>
</BaseLayout>
