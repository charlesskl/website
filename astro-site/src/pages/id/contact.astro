---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.tsx';
import '../../styles/contact.css';

const lang = 'id' as const;
const prefix = '/id';
---

<BaseLayout
  title="Hubungi Royal Regent Toys — Produsen Mainan | PT RRI, PT RRM"
  description="Hubungi Royal Regent Toys untuk pertanyaan manufaktur mainan OEM. Kantor di Hong Kong, pabrik di Dongguan, Tiongkok & Indonesia (PT RRI, PT RRM)."
  lang="id"
  canonical="https://royalregentgroup.com/id/contact.html"
  ogLocale="id_ID"
  ogLocaleAlternates={['en_US', 'zh_TW']}
  dataPage="contact"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys kontak, produsen mainan Hong Kong, pabrik mainan Dongguan, pabrik mainan Indonesia, PT RRI, PT RRM, RRI, RRM">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://royalregentgroup.com/id/" },
            { "@type": "ListItem", "position": 2, "name": "Hubungi Kami", "item": "https://royalregentgroup.com/id/contact.html" }
          ]
        },
        {
          "@type": "LocalBusiness",
          "name": "Royal Regent Toys",
          "url": "https://royalregentgroup.com",
          "logo": "https://royalregentgroup.com/assets/logo.webp",
          "description": "Produsen mainan OEM sejak 1987 — kantor pusat di Hong Kong dengan pabrik di Tiongkok & Indonesia.",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Unit 07-08, 12/F, Greenfield Tower, Concordia Plaza, No.1 Science Museum Road",
            "addressLocality": "Tsim Sha Tsui, Kowloon",
            "addressCountry": "HK"
          },
          "telephone": "+852-2425-0720",
          "email": "info@royalregenthk.com",
          "contactPoint": [
            {
              "@type": "ContactPoint",
              "telephone": "+852-2425-0720",
              "email": "info@royalregenthk.com",
              "contactType": "sales",
              "availableLanguage": ["English", "Indonesian"]
            }
          ],
          "sameAs": [
            "https://www.linkedin.com/company/royalregentgroup"
          ]
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <!-- PAGE HERO -->
  <section class="page-hero" id="main-content">
    <div class="container">
      <span class="page-hero-tag">Hubungi Kami</span>
      <h1>Mari kita diskusikan<br><span class="text-gradient">proyek Anda.</span></h1>
      <p>Baik Anda membutuhkan manufaktur OEM, percobaan sampel, atau hanya ingin tahu lebih banyak — tim kami siap merespons.</p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       CONTACT SECTION
       ═══════════════════════════════════════════════════════════════ -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: Contact Info -->
        <div class="contact-info">
          <div class="section-label reveal-up">Informasi Kontak</div>
          <h2 class="reveal-up">Setiap pertanyaan penting. Kami akan membalas Anda sesegera mungkin.</h2>
          <p class="reveal-up">Dari pertanyaan awal hingga sampling dan produksi penuh — tim kami mendukung setiap tahap proses. Baik Anda pemilik merek, pengecer, atau distributor, beritahu kami tentang proyek Anda dan kami akan merespons dengan cepat.</p>

          <div class="contact-detail reveal-up">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            </div>
            <div><h4>Lokasi Produksi</h4><p>Tiongkok dan Indonesia</p></div>
          </div>
          <div class="contact-detail reveal-up">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
            </div>
            <div><h4>Email</h4><p>info@royalregenthk.com</p></div>
          </div>

        </div>

        <!-- Right: Form (React Island) -->
        <div class="reveal-up">
          <ContactForm lang="id" client:load />
        </div>

      </div>
    </div>
  </section>

  <Footer lang={lang} />

</BaseLayout>
