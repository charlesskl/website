---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Loader from '../components/Loader.astro';
import '../styles/home.css';

const lang = 'en' as const;
const prefix = '';

const milestones = [
  { year: '1987', text: 'Founded in Sha Tau Kok — the first step in a 39-year manufacturing journey.' },
  { year: '2000', text: 'First soft toy production line launched — entering plush and costume manufacturing.' },
  { year: '2010', text: 'Doll production lines integrated sewing craftsmanship with plastic molding technology.' },
  { year: '2016', text: 'Entered remote control vehicle manufacturing — our highest-complexity category.' },
  { year: '2023', text: 'Officially entered Indonesia — a key milestone in global supply chain diversification.' },
  { year: '2025', text: 'Indonesia Phase II commences — strengthening responsiveness to international markets.' },
];

const marqueeItems = [
  'RC Car', 'Action Figures', 'Fashion Dolls', 'Baby Dolls', 'Vehicles',
  'Play Sets', 'Figurines / Collectibles', 'Outdoor Toys', 'Bath Toys',
  'Spinning Tops', 'Water Guns', 'Blaster', 'Stuffed Plush', 'Character Plush',
  'Weighted Plush', 'Musical / Sound Plush', 'Interactive Plush', 'Costumes',
];

const capabilities = [
  {
    id: 'plastic',
    num: '01',
    tag: 'PLASTIC',
    label: 'Plastic Toys',
    headline: 'Injection-molded precision.',
    body: 'Single-shot playsets to multi-material collectibles. Tooled, molded, assembled, and finished without leaving the floor.',
    href: '/capabilities/plastic-toys.html',
    bgImage: '/assets/images/stock/cap-plastic-bg.webp',
    fgImage: '/assets/images/stock/cap-plastic-fg.webp',
    bgAlt: 'Colorful plastic toy bricks',
    fgAlt: 'Colorful plastic toy figures',
  },
  {
    id: 'plush',
    num: '02',
    tag: 'PLUSH',
    label: 'Plush',
    headline: 'Soft goods, sewn to brand.',
    body: 'Short pile, long pile, weighted, interactive. Production scale that still carries a hand-finish.',
    href: '/capabilities/plush.html',
    bgImage: '/assets/images/stock/cap-plush-bg.webp',
    fgImage: '/assets/images/stock/cap-plush-fg.webp',
    bgAlt: 'Plush toy workshop',
    fgAlt: 'Plush teddy bear',
  },
  {
    id: 'dolls',
    num: '03',
    tag: 'DOLLS',
    label: 'Dolls',
    headline: 'Character detail, end-to-end.',
    body: 'Fashion, baby, and collector dolls — with hair-rooting, face painting, and costume work all finished in-house.',
    href: '/capabilities/dolls.html',
    bgImage: '/assets/images/stock/cap-dolls-bg.webp',
    fgImage: '/assets/images/stock/cap-dolls-fg.webp',
    bgAlt: 'Doll manufacturing',
    fgAlt: 'Fashion dolls',
  },
  {
    id: 'rc',
    num: '04',
    tag: 'RC VEHICLES',
    label: 'RC Vehicles',
    headline: 'Our hardest category.',
    body: 'Mechatronics, tooling, electronics, and testing under one roof. The reason brands bring their difficult specs to us.',
    href: '/capabilities/rc-vehicle.html',
    bgImage: '/assets/images/stock/cap-rc-bg.webp',
    fgImage: '/assets/images/stock/cap-rc-fg.webp',
    bgAlt: 'RC vehicle parts',
    fgAlt: 'Toy RC car',
  },
  {
    id: 'costumes',
    num: '05',
    tag: 'COSTUMES',
    label: 'Costumes',
    headline: 'Theatrical wear, production-grade.',
    body: 'Licensed character, seasonal, and dress-up. Cut, sewn, trimmed, and certified to US and EU safety standards.',
    href: '/capabilities/costume.html',
    bgImage: '/assets/images/stock/cap-costumes-bg.webp',
    fgImage: '/assets/images/stock/cap-costumes-fg.webp',
    bgAlt: 'Costume display',
    fgAlt: 'Child in superhero costume',
  },
];
---

<BaseLayout
  title="Royal Regent Toys — OEM Toy Manufacturer Since 1987"
  description="Royal Regent Toys — 39 years of OEM toy manufacturing. Plastic toys, plush, dolls, RC vehicles & costumes. Factories in China & Indonesia (PT RRI, PT RRM)."
  lang="en"
  canonical="https://royalregentgroup.com/"
  ogLocale="en_US"
  ogLocaleAlternates={['zh_TW', 'id_ID']}
  dataPage="home"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys, Royal Regent, OEM toy manufacturer, toy factory China, toy factory Indonesia, PT RRI, PT RRM, RRI, RRM, plastic toys, plush toys, dolls, RC vehicles, costumes, toy manufacturing partner">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Royal Regent Toys",
      "url": "https://royalregentgroup.com",
      "logo": "https://royalregentgroup.com/assets/logo.webp",
      "description": "OEM toy manufacturer since 1987. Plastic toys, plush, dolls, RC vehicles & costumes. Factories in China & Indonesia.",
      "foundingDate": "1987",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Unit 07-08, 12/F, Greenfield Tower, Concordia Plaza, No.1 Science Museum Road",
        "addressLocality": "Tsim Sha Tsui, Kowloon",
        "addressCountry": "HK"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+852-2425-0720",
        "email": "info@royalregenthk.com",
        "contactType": "sales"
      },
      "sameAs": ["https://www.linkedin.com/company/royalregentgroup"]
    })} />
  </Fragment>

  <Loader slot="loader" tagline="CRAFTING DREAMS SINCE 1987" />

  <Nav lang={lang} />

  <!-- Page-wide dotted thread — penetrates hero → statement → caps → history → CTA so the page reads as one coherent journey. The thread itself is a CSS repeating gradient; JS positions the glowing progress marker as the user scrolls. -->
  <div class="page-thread-wrap">
    <div class="page-thread" aria-hidden="true"></div>
    <div class="page-thread-dot" aria-hidden="true"></div>

  <!-- HERO — Cinematic video with brand tint + bottom text -->
  <section class="hero hero-cinematic page-reveal" id="hero">
    <div class="hero-video-wrap">
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      >
        <source src="/assets/videos/hero.mp4" type="video/mp4">
      </video>
      <div class="hero-cinematic-tint"></div>
    </div>

    <div class="hero-cinematic-content">
      <div class="hero-tag" id="heroTag">OEM Toy Manufacturer · Est. 1987</div>
      <h1 class="hero-cinematic-title" id="heroTitle">
        Precision. <span>Craftsmanship.</span> Global Scale.
      </h1>
      <p class="hero-cinematic-sub" id="heroSub">Great manufacturing isn't just about production — it's about partnership. For 39 years, we've worked alongside brands to bring their visions to life.</p>
      <div class="hero-cinematic-actions" id="heroActions">
        <a href="/capabilities/plastic-toys.html" class="btn btn-primary magnetic" data-strength="0.2">Explore Capabilities</a>
        <a href="/about.html" class="btn btn-outline magnetic" data-strength="0.2">Our Story →</a>
      </div>
    </div>

    <div class="hero-scroll-hint" id="heroScroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee" data-cursor="Drag">
    <div class="marquee-track" id="marqueeTrack">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <span class="marquee-item">{item} <span class="marquee-dot"></span></span>
      ))}
    </div>
  </div>

  <!-- Main content wrapper (for footer reveal) -->
  <div class="main-content" id="main-content">

    <!-- INTRO STATEMENT (unchanged) -->
    <section class="intro-statement clip-section" id="introStatement">
      <div class="statement-grid">
        <div class="statement-left">
          <div class="statement-line" id="stmtLine"></div>
          <div class="statement-content">
            <p class="statement-text">
              <span class="stmt-line">Built on trust.</span>
              <span class="stmt-line">Refined over decades.</span>
              <span class="stmt-line">Ready for what you need next.</span>
            </p>
            <div class="statement-rule" id="stmtRule"></div>
          </div>
        </div>
        <div class="statement-accent" id="stmtAccent">1987</div>
      </div>
    </section>

    <!-- CAPABILITIES — Sphinx "Agent in Action" pattern: scroll text left, sticky image right with parallax -->
    <section class="caps-sticky-section caps-sticky-cinematic clip-section" id="capsSection">
      <!-- Decorative layers -->
      <div class="caps-grid-pattern" aria-hidden="true"></div>
      <div class="caps-glow caps-glow-tl" aria-hidden="true"></div>
      <div class="caps-glow caps-glow-br" aria-hidden="true"></div>

      <!-- Section header -->
      <div class="container caps-sticky-header">
        <div class="section-chip reveal-up">Manufacturing Capabilities</div>
        <h2 class="section-title reveal-up">Five categories.<br><span>One trusted partner.</span></h2>
      </div>

      <!-- Split panel: 5 text blocks scroll naturally on the left, sticky image frame on the right -->
      <div class="caps-sticky-grid container">
        <div class="caps-sticky-left">
          {capabilities.map((cap, i) => (
            <article class={`cap-block${i === 0 ? ' in-view' : ''}`} data-index={i} data-cap={cap.id}>
              <div class="cap-block-num" aria-hidden="true">{cap.num}</div>
              <div class="cap-eyebrow">
                <span class="cap-eyebrow-bar"></span>
                <span class="cap-eyebrow-num">{cap.num}</span>
                <span class="cap-eyebrow-sep">/</span>
                <span class="cap-eyebrow-tag">{cap.tag}</span>
              </div>
              <h3 class="cap-headline">{cap.headline}</h3>
              <p class="cap-body">{cap.body}</p>
              <a href={cap.href} class="cap-link"><span class="cap-link-line"></span>Explore capability <span class="cap-link-arrow">→</span></a>
            </article>
          ))}
        </div>

        <div class="caps-sticky-right">
          <div class="caps-sticky-frame">
            {capabilities.map((cap, i) => (
              <div
                class={`cap-visual${i === 0 ? ' active' : ''}`}
                data-index={i}
                data-cap={cap.id}
              >
                <div class="cap-visual-bg">
                  <img src={cap.bgImage} alt="" loading={i === 0 ? 'eager' : 'lazy'} width="800" height="500">
                </div>
                <div class="cap-visual-fg">
                  <img src={cap.fgImage} alt={cap.fgAlt} loading={i === 0 ? 'eager' : 'lazy'} width="600" height="400">
                </div>
                <div class="cap-visual-cinematic-overlay" aria-hidden="true"></div>
                <div class="cap-visual-tag">{cap.tag}</div>
                <div class="cap-visual-label">{cap.label}</div>
              </div>
            ))}
            <!-- Corner brackets -->
            <span class="cap-frame-corner cap-frame-corner-tl"></span>
            <span class="cap-frame-corner cap-frame-corner-tr"></span>
            <span class="cap-frame-corner cap-frame-corner-bl"></span>
            <span class="cap-frame-corner cap-frame-corner-br"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- HISTORY — Video background -->
    <section class="history-section clip-section" id="historySection" data-milestones={JSON.stringify(milestones)}>
      <div class="history-bg history-bg-video" id="historyBg">
        <video
          class="history-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        >
          <source src="/assets/videos/history.mp4" type="video/mp4">
        </video>
      </div>

      <div class="history-top">
        <h2 class="history-heading">Development history</h2>
      </div>

      <div class="history-center">
        <div class="history-watermark" id="historyWatermark">1987</div>
        <div class="history-milestone" id="historyMilestone">
          <p>Founded in Sha Tau Kok — the first step in a 39-year manufacturing journey.</p>
        </div>
      </div>

      <div class="history-scroll-progress">
        <div class="history-scroll-fill" id="historyScrollFill"></div>
      </div>

      <div class="history-scroll-hint" id="historyScrollHint">
        <span>Scroll to explore</span>
        <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
      </div>

      <div class="history-timeline">
        <div class="timeline-track" id="timelineTrack">
          {milestones.map((m, i) => (
            <button class={`timeline-node${i === 0 ? ' active' : ''}`} data-index={i}>
              <div class="timeline-dot"><span>{m.year}</span></div>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA BANNER — Sphinx-style two-column: statement left, actions right -->
    <section class="cta-banner cta-split clip-section" data-reveal>
      <div class="container cta-split-grid">
        <div class="cta-split-left">
          <div class="section-chip">Let's Work Together</div>
          <h2>Ready to bring your next product<br><span>to life?</span></h2>
        </div>
        <div class="cta-split-right">
          <a href="/contact.html" class="btn btn-primary magnetic" data-strength="0.2">Start a Conversation →</a>
          <a href="/capabilities/plastic-toys.html" class="btn btn-outline magnetic" data-strength="0.2">See Capabilities →</a>
          <div class="cta-response-chip">
            <span class="cta-response-dot" aria-hidden="true"></span>Response within 24 hours
          </div>
        </div>
      </div>
    </section>

  </div>
  </div><!-- /.page-thread-wrap -->

  <Footer lang={lang} />

  <Fragment slot="page-scripts">
    <script is:inline src="/assets/home-canvas.js"></script>
    <script is:inline src="/assets/home-animations.js"></script>
    <script is:inline>
      (function () {
        'use strict';

        // Wait for GSAP + ScrollTrigger to finish loading (they come after
        // this slot in BaseLayout). DOMContentLoaded fires after blocking
        // <script src> tags execute, so gsap is available by then.
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }

        function init() {

        // ── Pause background videos when off-screen (perf) ──
        var videos = document.querySelectorAll('.hero-video, .history-video');
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              var v = e.target;
              if (e.isIntersecting) { v.play().catch(function(){}); }
              else { v.pause(); }
            });
          }, { threshold: 0.1 });
          videos.forEach(function (v) { io.observe(v); });
        }

        // ── Capabilities — Sphinx-style sticky split ──
        // Left: 5 text blocks scroll naturally. Right: ONE sticky frame whose
        // active image swaps to match whichever left block is centered in the
        // viewport. Right image also parallaxes subtly as the active block
        // passes through the viewport (Ken-Burns drift).
        var capBlocks = Array.prototype.slice.call(document.querySelectorAll('.caps-sticky-section .cap-block'));
        var capVisuals = Array.prototype.slice.call(document.querySelectorAll('.caps-sticky-section .cap-visual'));

        if (capBlocks.length && capVisuals.length) {
          var activeCapIndex = 0;
          function activateCap(i) {
            if (i === activeCapIndex) return;
            activeCapIndex = i;
            capBlocks.forEach(function (b, j) { b.classList.toggle('in-view', j === i); });
            capVisuals.forEach(function (v, j) { v.classList.toggle('active', j === i); });
          }

          if ('IntersectionObserver' in window) {
            // Trigger activation when a block's center crosses the viewport center.
            // rootMargin collapses the activation zone to the middle 20% of the viewport.
            var capIO = new IntersectionObserver(function (entries) {
              // Take the most visible entry and activate it.
              var best = null;
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  if (!best || e.intersectionRatio > best.intersectionRatio) best = e;
                }
              });
              if (best) {
                var idx = parseInt(best.target.getAttribute('data-index'), 10);
                if (!isNaN(idx)) activateCap(idx);
              }
            }, {
              rootMargin: '-40% 0px -40% 0px', // middle 20% of viewport
              threshold: [0, 0.1, 0.3, 0.5, 0.7, 1],
            });
            capBlocks.forEach(function (b) { capIO.observe(b); });
          }

          // Ken-Burns parallax on the active image, tied to window scroll progress
          // through the caps section. Image scales from 1.12 → 1.0 and translates
          // from -20px → +20px as the section passes through the viewport.
          var capsSection = document.getElementById('capsSection');
          if (capsSection && typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
            ScrollTrigger.create({
              trigger: capsSection,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 0.6,
              onUpdate: function (self) {
                var p = self.progress; // 0..1 across the whole section
                var ty = -20 + p * 40;  // -20 → +20 px
                var sc = 1.12 - p * 0.12; // 1.12 → 1.00
                capVisuals.forEach(function (v) {
                  var img = v.querySelector('.cap-visual-bg img');
                  if (img) {
                    img.style.transform = 'translate3d(0,' + ty.toFixed(2) + 'px,0) scale(' + sc.toFixed(3) + ')';
                  }
                });
              },
            });

            window.addEventListener('resize', function () { ScrollTrigger.refresh(); });
          }
        }

        // ── Page-wide dotted thread: progress marker ──
        // Thread SVG is static inside .page-thread-wrap. A small bright dot
        // (".page-thread-dot") is position:fixed and its top value tracks
        // scroll progress — so the dot slides from top of the thread to the
        // bottom as the reader scrolls through the page.
        var threadDot = document.querySelector('.page-thread-dot');
        var threadWrap = document.querySelector('.page-thread-wrap');
        if (threadDot && threadWrap) {
          function updateThreadDot() {
            var rect = threadWrap.getBoundingClientRect();
            var vh = window.innerHeight;
            // Map scroll position of the wrap relative to viewport top into [0,1]
            var total = rect.height - vh;
            if (total <= 0) { threadDot.style.opacity = '0'; return; }
            var scrolled = Math.min(Math.max(-rect.top, 0), total);
            var p = scrolled / total;
            // Dot travels from 12% to 92% down the viewport (keeps it away from nav + footer overlap)
            var topPct = 12 + p * 80;
            threadDot.style.top = topPct + 'vh';
            // Fade in after hero, fade out near footer
            var op = p <= 0.02 ? p / 0.02 : (p >= 0.98 ? (1 - p) / 0.02 : 1);
            threadDot.style.opacity = Math.max(0, Math.min(1, op)).toFixed(2);
          }
          updateThreadDot();
          window.addEventListener('scroll', updateThreadDot, { passive: true });
          window.addEventListener('resize', updateThreadDot);
        }
        } // end init()
      })();
    </script>
  </Fragment>
</BaseLayout>
