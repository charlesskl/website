---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.tsx';
import '../styles/contact.css';

const lang = 'en' as const;
const prefix = '';
---

<BaseLayout
  title="Contact Royal Regent Toys — Hong Kong Toy Manufacturer"
  description="Contact Royal Regent Toys for OEM toy manufacturing inquiries. Hong Kong headquarters, factories in Dongguan, Heyuan, Hunan (China) & Indonesia (PT RRI, PT RRM)."
  lang="en"
  canonical="https://royalregentgroup.com/contact.html"
  ogLocale="en_US"
  ogLocaleAlternates={['zh_TW', 'id_ID']}
  dataPage="contact"
>
  <Fragment slot="head-extra">
    <meta name="keywords" content="Royal Regent Toys contact, toy manufacturer Hong Kong, Dongguan toy factory, Indonesia toy factory, PT RRI, PT RRM, RRI, RRM, OEM toy inquiry">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://royalregentgroup.com/" },
            { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://royalregentgroup.com/contact.html" }
          ]
        },
        {
          "@type": "LocalBusiness",
          "name": "Royal Regent Toys",
          "url": "https://royalregentgroup.com",
          "logo": "https://royalregentgroup.com/assets/logo.webp",
          "description": "OEM toy manufacturer since 1987 — Hong Kong headquarters with factories in China & Indonesia.",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Unit 07-08, 12/F, Greenfield Tower, Concordia Plaza, No.1 Science Museum Road",
            "addressLocality": "Tsim Sha Tsui, Kowloon",
            "addressCountry": "HK"
          },
          "telephone": "+852-2425-0720",
          "email": "info@royalregenthk.com",
          "contactPoint": [
            {
              "@type": "ContactPoint",
              "telephone": "+852-2425-0720",
              "email": "info@royalregenthk.com",
              "contactType": "sales",
              "availableLanguage": ["English", "Chinese"]
            }
          ],
          "sameAs": [
            "https://www.linkedin.com/company/royalregentgroup"
          ]
        }
      ]
    })} />
  </Fragment>

  <Nav lang={lang} />

  <!-- PAGE HERO -->
  <section class="page-hero" id="main-content">
    <div class="container">
      <span class="page-hero-tag">Get In Touch</span>
      <h1>Let's discuss<br><span class="text-gradient">your project.</span></h1>
      <p>Whether you need OEM manufacturing, a sample run, or just want to learn more — our team is ready to respond.</p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       CONTACT SECTION
       ═══════════════════════════════════════════════════════════════ -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: Contact Info -->
        <div class="contact-info">
          <div class="section-label reveal-up">Contact Information</div>
          <h2 class="reveal-up">Every inquiry matters. We'll get back to you as soon as we can.</h2>
          <p class="reveal-up">From initial inquiry through sampling and into full production — our team supports every stage of the process. Whether you are a brand owner, retailer, or distributor, tell us about your project and we will respond promptly.</p>

          <div class="contact-detail reveal-up">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            </div>
            <div><h4>Production sites</h4><p>China and Indonesia</p></div>
          </div>
          <div class="contact-detail reveal-up">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
            </div>
            <div><h4>Email</h4><p>info@royalregenthk.com</p></div>
          </div>

        </div>

        <!-- Right: Form (React Island) -->
        <div class="reveal-up">
          <ContactForm lang="en" client:load />
        </div>

      </div>
    </div>
  </section>

  <Footer lang={lang} />

</BaseLayout>
