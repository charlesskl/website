---
interface Props {
  lang: 'en' | 'cn' | 'id';
}

const { lang } = Astro.props;

const prefix = lang === 'en' ? '' : `/${lang}`;

const footer = {
  en: {
    brandDesc: 'Manufacturing partner to the world\'s leading toy brands since 1987. Five product categories, four production sites, one consistent standard &mdash; US and EU compliant.',
    chinaLabel: 'China',
    chinaAddr: 'Dongguan &amp; Heyuan,<br>Guangdong Province',
    indonesiaLabel: 'Indonesia',
    indonesiaAddr: 'Tangerang,<br>Banten Province',
    company: 'Company',
    about: 'About Us',
    careers: 'Careers',
    contact: 'Contact Us',
    capabilities: 'Capabilities',
    plasticToys: 'Plastic Toys',
    plush: 'Plush',
    dolls: 'Dolls',
    rcVehicles: 'RC Vehicles',
    costumes: 'Costumes',
    getInTouch: 'Get In Touch',
    address: 'Unit 07-08, 12/F, Greenfield Tower,<br>Concordia Plaza, No.1 Science Museum Road,<br>Tsim Sha Tsui, Kowloon, Hong Kong',
    copyright: 'Royal Regent Toys. All rights reserved.',
  },
  cn: {
    brandDesc: '自1987年以來，華登集團一直是全球領先玩具品牌的製造合作夥伴。五大產品類別、四個生產基地、一個統一標準&mdash;符合美國及歐盟標準。',
    chinaLabel: '中國',
    chinaAddr: '東莞及河源，<br>廣東省',
    indonesiaLabel: '印尼',
    indonesiaAddr: '坦格朗，<br>萬丹省',
    company: '公司',
    about: '關於我們',
    careers: '招聘',
    contact: '聯繫我們',
    capabilities: '生產能力',
    plasticToys: '塑膠玩具',
    plush: '毛絨玩具',
    dolls: '娃娃',
    rcVehicles: '遙控車',
    costumes: '服裝',
    getInTouch: '聯繫方式',
    address: '香港九龍尖沙咀<br>科學館道1號<br>康宏廣場翠庭樓12樓07-08室',
    copyright: 'Royal Regent Toys. 版權所有。',
  },
  id: {
    brandDesc: 'Mitra manufaktur bagi merek mainan terkemuka dunia sejak 1987. Lima kategori produk, empat lokasi produksi, satu standar konsisten &mdash; sesuai standar AS dan UE.',
    chinaLabel: 'Tiongkok',
    chinaAddr: 'Dongguan &amp; Heyuan,<br>Provinsi Guangdong',
    indonesiaLabel: 'Indonesia',
    indonesiaAddr: 'Tangerang,<br>Provinsi Banten',
    company: 'Perusahaan',
    about: 'Tentang Kami',
    careers: 'Karier',
    contact: 'Hubungi Kami',
    capabilities: 'Kapabilitas',
    plasticToys: 'Mainan Plastik',
    plush: 'Boneka Plush',
    dolls: 'Boneka',
    rcVehicles: 'Kendaraan RC',
    costumes: 'Kostum',
    getInTouch: 'Hubungi Kami',
    address: 'Unit 07-08, 12/F, Greenfield Tower,<br>Concordia Plaza, No.1 Science Museum Road,<br>Tsim Sha Tsui, Kowloon, Hong Kong',
    copyright: 'Royal Regent Toys. Hak cipta dilindungi.',
  },
}[lang];
---

<footer class="footer-reveal">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/assets/logo.webp" alt="Royal Regent Toys" class="footer-logo" width="200" height="40">
        <p set:html={footer.brandDesc} />
        <div class="footer-factories">
          <div class="footer-factory">
            <div class="footer-factory-label">{footer.chinaLabel}</div>
            <p set:html={footer.chinaAddr} />
          </div>
          <div class="footer-factories-divider"></div>
          <div class="footer-factory">
            <div class="footer-factory-label">{footer.indonesiaLabel}</div>
            <p set:html={footer.indonesiaAddr} />
          </div>
        </div>
      </div>
      <div class="footer-col">
        <h4>{footer.company}</h4>
        <a href={`${prefix}/about.html`}>{footer.about}</a>
        <a href={`${prefix}/careers.html`}>{footer.careers}</a>
        <a href={`${prefix}/contact.html`}>{footer.contact}</a>
      </div>
      <div class="footer-col">
        <h4>{footer.capabilities}</h4>
        <a href={`${prefix}/capabilities/plastic-toys.html`}>{footer.plasticToys}</a>
        <a href={`${prefix}/capabilities/plush.html`}>{footer.plush}</a>
        <a href={`${prefix}/capabilities/dolls.html`}>{footer.dolls}</a>
        <a href={`${prefix}/capabilities/rc-vehicle.html`}>{footer.rcVehicles}</a>
        <a href={`${prefix}/capabilities/costume.html`}>{footer.costumes}</a>
      </div>
      <div class="footer-col">
        <h4>{footer.getInTouch}</h4>
        <p class="footer-address" set:html={footer.address} />
        <a href="mailto:info@royalregenthk.com">info@royalregenthk.com</a>
        <a href="tel:+85224250720">(852) 2425 0720</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <span id="footerYear"></span> {footer.copyright}</p>
      <script is:inline>document.getElementById('footerYear').textContent=new Date().getFullYear();</script>
    </div>
  </div>
</footer>
