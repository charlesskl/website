---
interface Props {
  tagline?: string;
}

const { tagline = 'CRAFTING DREAMS SINCE 1987' } = Astro.props;

// Split tagline into individual characters, preserving spaces
const chars = tagline.split('');
---

<div class="brand-loader" id="brandLoader">
  <div class="loader-ring-wrap">
    <svg class="loader-ring" viewBox="0 0 200 200" width="200" height="200">
      <circle class="loader-ring-bg" cx="100" cy="100" r="96"/>
      <circle class="loader-ring-fill" cx="100" cy="100" r="96"/>
    </svg>
    <div class="loader-logo"><img src="/assets/logo.webp" alt="" role="presentation" width="962" height="467"></div>
  </div>
  <div class="loader-percent">0%</div>
  <div class="loader-tagline"><!--
    -->{chars.map((char) => (
      char === ' '
        ? <span class="space"> </span>
        : <span>{char}</span>
    ))}<!--
  --></div>
</div>
