---
import LanguageSwitcher from './LanguageSwitcher.tsx';

interface Props {
  lang: 'en' | 'cn' | 'id';
}

const { lang } = Astro.props;

const prefix = lang === 'en' ? '' : `/${lang}`;

const nav = {
  en: {
    about: 'About',
    capabilities: 'Capabilities',
    plasticToys: 'Plastic Toys',
    plush: 'Plush',
    dolls: 'Dolls',
    rcVehicles: 'RC Vehicles',
    costumes: 'Costumes',
    careers: 'Careers',
    contact: 'Contact Us',
  },
  cn: {
    about: '關於我們',
    capabilities: '生產能力',
    plasticToys: '塑膠玩具',
    plush: '毛絨玩具',
    dolls: '娃娃',
    rcVehicles: '遙控車',
    costumes: '服裝',
    careers: '招聘',
    contact: '聯繫我們',
  },
  id: {
    about: 'Tentang Kami',
    capabilities: 'Kapabilitas',
    plasticToys: 'Mainan Plastik',
    plush: 'Boneka Plush',
    dolls: 'Boneka',
    rcVehicles: 'Kendaraan RC',
    costumes: 'Kostum',
    careers: 'Karier',
    contact: 'Hubungi Kami',
  },
}[lang];
---

<nav id="navbar" class="page-reveal">
  <div class="nav-container">
    <a href={lang === 'en' ? '/index.html' : `/${lang}.html`} class="nav-logo">
      <img src="/assets/logo.webp" alt="Royal Regent Toys" width="200" height="40">
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href={`${prefix}/about.html`}>{nav.about}</a></li>
      <li class="has-dropdown">
        <button type="button" aria-expanded="false" aria-haspopup="true">{nav.capabilities} <span class="arrow">&#8964;</span></button>
        <ul class="dropdown">
          <li><a href={`${prefix}/capabilities/plastic-toys.html`}><svg class="dd-icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>{nav.plasticToys}<svg class="dd-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></li>
          <li><a href={`${prefix}/capabilities/plush.html`}><svg class="dd-icon" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>{nav.plush}<svg class="dd-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></li>
          <li><a href={`${prefix}/capabilities/dolls.html`}><svg class="dd-icon" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>{nav.dolls}<svg class="dd-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></li>
          <li><a href={`${prefix}/capabilities/rc-vehicle.html`}><svg class="dd-icon" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>{nav.rcVehicles}<svg class="dd-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></li>
          <li><a href={`${prefix}/capabilities/costume.html`}><svg class="dd-icon" viewBox="0 0 24 24"><path d="M12 3l1.5 3.2 3.5.5-2.5 2.5.6 3.5L12 11l-3.1 1.7.6-3.5L7 6.7l3.5-.5z"/><path d="M5 16l-1.5 3.2-3.5.5L2.5 22l-.6 2L5 22.3 8.1 24l-.6-2L10 19.5l-3.5-.5z"/><path d="M19 16l-1.5 3.2-3.5.5 2.5 2.5-.6 2L19 22.3l3.1 1.7-.6-2L24 19.5l-3.5-.5z"/></svg>{nav.costumes}<svg class="dd-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></li>
        </ul>
      </li>
      <li><a href={`${prefix}/careers.html`}>{nav.careers}</a></li>
      <LanguageSwitcher lang={lang} client:load />
      <li class="nav-linkedin"><a href="https://www.linkedin.com/company/royalregentgroup" target="_blank" rel="noopener noreferrer"><svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg><span class="nav-linkedin-text">LinkedIn</span></a></li>
      <li><a href={`${prefix}/contact.html`} class="nav-cta">{nav.contact}</a></li>
    </ul>
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
